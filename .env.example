# ========================================
# Database Configuration
# ========================================
# Path to SQLite database file
PUBLIC_DB_PATH=./data/manhau.db

# ========================================
# API Configuration
# ========================================
# API request timeout in milliseconds
PUBLIC_API_TIMEOUT=5000

# API base URL (for external services)
PUBLIC_API_BASE_URL=https://api.example.com

# ========================================
# Feature Flags
# ========================================
# Enable analytics (Google Analytics 4)
PUBLIC_ENABLE_ANALYTICS=true

# Enable offline mode and service worker
PUBLIC_ENABLE_OFFLINE_MODE=true

# Enable debug mode (console logs)
PUBLIC_DEBUG=false

# ========================================
# Analytics (Optional)
# ========================================
# Google Analytics 4 Measurement ID
# Get yours from https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ========================================
# Error Tracking (Optional)
# ========================================
# Sentry DSN for error tracking and monitoring
# Get yours from https://sentry.io
VITE_SENTRY_DSN=

# ========================================
# Deployment
# ========================================
# Environment (development, staging, production)
NODE_ENV=development

# Cloudflare Pages configuration (if using CF deployment)
CF_ACCOUNT_ID=
CF_API_TOKEN=
